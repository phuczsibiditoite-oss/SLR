MainTab:AddToggle("Instant Interact", function(v)
    Settings.InstantInteract = v
    
    local function FastPrompt(obj)
        if obj:IsA("ProximityPrompt") then
            -- Nếu bật thì chỉnh về 0, nếu tắt thì trả về mặc định (thường là 1 hoặc tùy game)
            obj.HoldDuration = v and 0 or obj.HoldDuration
        end
    end

    if v then
        for _, descendant in pairs(workspace:GetDescendants()) do
            -- Kiểm tra nếu tên là Interact hoặc có chứa Prompt bên trong
            if descendant.Name == "Interact" or descendant:IsA("ProximityPrompt") then
                if descendant:IsA("ProximityPrompt") then
                    FastPrompt(descendant)
                else
                    local prompt = descendant:FindFirstChildOfClass("ProximityPrompt")
                    if prompt then FastPrompt(prompt) end
                end
            end
        end
    end
end)

workspace.DescendantAdded:Connect(function(descendant)
    if Settings.InstantInteract then
        task.wait(0.1) -- Đợi object load xong
        if descendant.Name == "Interact" or descendant:IsA("ProximityPrompt") then
            if descendant:IsA("ProximityPrompt") then
                descendant.HoldDuration = 0
            else
                local prompt = descendant:FindFirstChildOfClass("ProximityPrompt")
                if prompt then prompt.HoldDuration = 0 end
            end
        end
    end
end)

